{
  "manifest_version": 3,
  "name": "Ekko - Language Learning for YouTube",
  "version": "1.0.1",
  "description": "Learn languages through YouTube videos with interactive shadowing practice",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://m.youtube.com/*",
    "https://*.supabase.co/*",
    "https://api.mymemory.translated.net/*",
    "https://httpbin.org/*"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*", "https://youtube.com/watch*"],
      "js": ["src/content/enhanced-video-control.js", "src/content/content.js", "src/content/debug-enhanced-mode.js"],
      "css": ["src/content/content.css", "src/theater-mode.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/content/theater-mode.css",
        "src/content/content.css",
        "src/content/enhanced-theater-mode.css",
        "src/content/enhanced-theater-mode.js",
        "src/player/*",
        "icons/*"
      ],
      "matches": ["https://www.youtube.com/*", "https://youtube.com/*", "https://m.youtube.com/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
